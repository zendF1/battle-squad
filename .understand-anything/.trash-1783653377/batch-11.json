      "filePath": "internal/admin/templates/map_editor.html",
      "summary": "Template HTML cho map editor canvas-based: toolbar với các tool (Paint/Erase/Fill/Select/Spawn), canvas fullscreen với coordinate display, panel properties bên phải với Map Settings đầy đủ (name/grid/wind/min_rank_tier/description) và spawn points list. Load map_editor.js.",
      "tags": ["template", "admin", "map-editor", "canvas", "tilemap", "spawn-points", "min-rank-tier", "html"],
      "complexity": "high"
    },
