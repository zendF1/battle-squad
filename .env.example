# Battle Squad - Environment Configuration Example

# Server settings
APP_ENV=development
API_PORT=8080
GAME_PORT=8081
APP_VERSION=1.0.0
PROTOCOL_VERSION=1

# PostgreSQL Database DSN
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/battlesquad?sslmode=disable

# Redis Cache/Registry settings
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
JWT_SECRET=super-secret-battle-squad-key-2026

# Node Configuration
NODE_ID=node-game-1
