FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /game ./cmd/game

FROM alpine:3.20
RUN apk --no-cache add ca-certificates && adduser -D -u 1000 appuser
COPY --from=builder /game /game
COPY --from=builder /app/configs/ /configs/
USER appuser
EXPOSE 8081
HEALTHCHECK --interval=30s --timeout=5s CMD wget -qO- http://localhost:8081/healthz || exit 1
ENTRYPOINT ["/game"]
